# Optional Environment Configuration Example
# Copy this to .env or set as environment variables

# Matrix homeserver URL (e.g. https://matrix.org)
PI_MATRIX_BRIDGE_HOMESERVER=https://matrix.org

# Matrix access token
PI_MATRIX_BRIDGE_ACCESS_TOKEN=mat_your-access-token

# Connect on startup. Defaults OFF — set to 1 to activate the bridge (the
# systemd unit sets this for you). Left unset, the plugin stays dormant and you
# can connect manually with /matrix-bridge connect.
PI_MATRIX_BRIDGE_AUTO_CONNECT=1
