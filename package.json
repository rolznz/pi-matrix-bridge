{
  "name": "pi-matrix-bridge",
  "version": "0.4.0",
  "description": "Bridge Matrix into pi (Matrix-only fork of pi-messenger-bridge)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "pi": {
    "extensions": [
      "./dist/index.js"
    ],
    "video": "https://github.com/rolznz/pi-matrix-bridge/raw/master/media/demo.mp4",
    "image": "https://github.com/rolznz/pi-matrix-bridge/raw/master/media/screenshot.png"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "matrix",
    "element",
    "messenger",
    "bridge",
    "bot",
    "remote",
    "chat",
    "messaging",
    "coding-agent"
  ],
  "author": "Roland Bewick",
  "contributors": [
    "tintinweb (original pi-messenger-bridge)"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rolznz/pi-matrix-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/rolznz/pi-matrix-bridge/issues"
  },
  "homepage": "https://github.com/rolznz/pi-matrix-bridge#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.74",
    "@earendil-works/pi-coding-agent": ">=0.74",
    "@earendil-works/pi-tui": ">=0.74"
  },
  "dependencies": {
    "matrix-bot-sdk": "^0.8.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.2",
    "fast-check": "^4.5.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
